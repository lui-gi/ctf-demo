<!doctype html>
<html lang="en"><head><meta charset="utf-8">
<title>Hesperus Harbourmaster — Login</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  body{font:15px/1.5 -apple-system,BlinkMacSystemFont,Segoe UI,sans-serif;background:#0c1c2e;color:#f3e6c8;margin:0;padding:32px}
  main{max-width:480px;margin:0 auto;background:#10283f;padding:24px;border:1px solid #1f3a5a;border-radius:8px}
  h1{font-size:20px;margin:0 0 4px;letter-spacing:.3px}
  .sub{color:#a7b4c2;font-size:13px;margin-bottom:18px}
  label{display:block;margin:10px 0;color:#cdd6df;font-size:13px}
  input{width:100%;box-sizing:border-box;padding:8px 10px;background:#0c1c2e;color:#f3e6c8;border:1px solid #1f3a5a;border-radius:4px;font:inherit}
  button{margin-top:12px;padding:8px 14px;background:#7a1f1f;color:#f3e6c8;border:0;border-radius:4px;cursor:pointer;font-weight:600}
  button:hover{background:#962727}
  .err{margin-top:18px;padding:12px;background:#1a0e0e;color:#f7b9b9;border:1px solid #4a1f1f;border-radius:4px;white-space:pre-wrap;word-break:break-word;font:12px/1.4 ui-monospace,SFMono-Regular,Menlo,monospace}
  footer{margin-top:18px;color:#6f7d8c;font-size:12px;text-align:center}
</style>
</head><body>
<main>
  <h1>Hesperus Harbourmaster</h1>
  <div class="sub">Authorised personnel only. Logbook access requires login.</div>
  <form method="post" action="/login" autocomplete="off" spellcheck="false">
    <label>Username
      <input name="username" type="text" required>
    </label>
    <label>Password
      <input name="password" type="password" required>
    </label>
    <button type="submit">Sign in</button>
  </form>
  <% if (error) { %>
    <pre class="err"><%= error %></pre>
  <% } %>
  <footer>HMS Hesperus · est. 1847 · last refit: never</footer>
</main>
</body></html>
