# progctf backend — environment template
# Copy to .env and fill in real values for local dev

NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# PostgreSQL
DB_URL=postgres://progctf:progctf@localhost:5432/progctf

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-string-please
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=30d

# Argon2id pepper (extra secret mixed into the flag hashing routine)
# Generate with: openssl rand -base64 32
ARGON2_PEPPER=change-me-to-a-long-random-pepper

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cookie config
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Sandbox controller (Shipwright)
SANDBOX_CONTROLLER_URL=http://localhost:8080
SANDBOX_CONTROLLER_TOKEN=change-me

# Charts cache TTL (seconds)
CHARTS_CACHE_TTL=5

# Submission rate limit (per crew per island)
SUBMIT_RATE_PER_MIN=5

# Auth rate limit (per IP)
AUTH_RATE_PER_MIN=10
