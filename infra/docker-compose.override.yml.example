# =========================================================================
# Local-dev override — copy to docker-compose.override.yml and edit.
# Compose auto-merges this file when present. NEVER commit the merged
# version (it contains dev-only secrets). The .yml.example is the only
# tracked file.
# =========================================================================

# Provide the required env vars via a shell `export` or by sourcing a
# .env file from infra/. Compose reads .env automatically:
#
#   POSTGRES_USER=progctf
#   POSTGRES_PASSWORD=devpassword_change_me
#   POSTGRES_DB=progctf
#   MINIO_ROOT_USER=progctf
#   MINIO_ROOT_PASSWORD=devminiopw_change_me
#   JWT_SECRET=$(openssl rand -base64 64)
#   ARGON2_PEPPER=$(openssl rand -base64 32)
#   SANDBOX_CONTROLLER_TOKEN=devtoken
#
# This override file's job is to expose the *internal* services on the host
# for local debugging. None of these ports are published in the committed
# infra/docker-compose.yml.

services:
  postgres:
    ports:
      - "5432:5432"

  redis:
    ports:
      - "6379:6379"

  minio:
    ports:
      - "9000:9000"   # S3 API
      - "9001:9001"   # MinIO web console — http://localhost:9001

  backend:
    ports:
      - "4000:4000"   # Bosun's API direct (bypasses edge for debugger attach)
    # Mount source for live reload during dev:
    # volumes:
    #   - ../backend:/app:cached
    # command: ["npm", "run", "dev"]

  frontend:
    ports:
      - "5173:8080"   # nginx-served bundle direct
