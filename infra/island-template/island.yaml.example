# ===========================================================================
# island.yaml — TEMPLATE for Powder Monkey.
#
# Each hosted Island ships exactly one of these alongside its Dockerfile.
# The sandbox-controller reads this file to decide:
#   - per-Crew or shared instance
#   - resource limits
#   - which secret holds the flag
#   - idle TTL before tearing down a Crew's instance
#
# Drop this file at:
#   challenges/<category>/<difficulty>/<slug>/island.yaml
# Powder Monkey adapts each field. Shipwright validates against the schema
# in infra/k8s/sandbox-controller/schema.json (see that file for the full
# JSON Schema — what's below is the canonical example).
# ===========================================================================

# Stable identifier — must match the DB row's `slug`. snake_case, prefixed
# with category for readability.
slug: cursed_ports_open_sea_jolly_admin

# Category from spec: cursed_ports | cipher_cove | shipwrights_forge
#                     lighthouse   | crows_nest  | hidden_cargo | keymaster
category: cursed_ports

# Difficulty: port | open_sea | cursed_depths
difficulty: open_sea

# Isolation model.
#   per_crew  — each Crew gets a fresh container on first visit, torn down
#               after `ttl_idle_minutes`. Default for any Cursed Ports Island.
#   shared    — single read-only instance the whole fleet hits. Use for
#               static artifact-style Islands (file server, single PCAP host).
isolation: per_crew

# Resource limits the sandbox-controller stamps onto the K8s pod spec.
# Default ceiling is cpu=0.5 / mem=512Mi. Cursed Depths Islands may bump
# either field — Shipwright reviews any request above cpu=2 / mem=2Gi.
resources:
  cpu: "0.5"
  memory: "512Mi"

# Exactly one port. The sandbox-controller will publish it behind the auth
# gateway at:  https://<voyage>/sandbox/<crew_slug>/<island_slug>/
ports: [8080]

# Idle minutes before this Crew's instance is reaped. Only meaningful when
# isolation == per_crew. 30 is the spec default.
ttl_idle_minutes: 30

# Container image — fully qualified, pinned tag (NEVER `latest`).
# Built and pushed by CI from this Island's Dockerfile.
image: ghcr.io/deadwake/progctf/cursed_ports_open_sea_jolly_admin:0.1.0

# Environment fed into the container at start.
# The CHALLENGE_FLAG value here is the *secret reference*, not the literal
# flag. The sandbox-controller resolves `secret://island-flags/<slug>` to
# the value of key `<slug>` in the `island-flags` K8s Secret at pod boot.
env:
  CHALLENGE_FLAG: "secret://island-flags/cursed_ports_open_sea_jolly_admin"
  # Add Island-specific knobs here. Anything starting with `secret://` is
  # resolved from a K8s Secret. Plain strings are passed through verbatim.
  LOG_LEVEL: "info"

# Optional: extra read-only files mounted from a ConfigMap (e.g. a fixture
# database, a static set of users). Omit if not needed.
# fixtures:
#   - name: seed-users
#     mountPath: /app/fixtures/users.json
#     configMapKey: seed-users.json

# Optional: which K8s NetworkPolicy to attach. Defaults to
# `island-sandbox-allow` (no public egress, ingress from edge only).
# Override only after Shipwright review.
# networkPolicy: island-sandbox-allow
