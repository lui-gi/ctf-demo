{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "The Voyage — operator overview. Submissions, Charts cache latency, sandbox inventory, error rates, P95 latency.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Successful + failed flag submissions per second.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (correct) (rate(progctf_submissions_total[1m]))", "legendFormat": "correct={{correct}}", "refId": "A"}
      ],
      "title": "Submissions / sec",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Time since the last write to The Charts Redis cache. >5s means the 5s TTL was missed.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [
        {"expr": "time() - max(progctf_charts_cache_last_write_seconds)", "legendFormat": "lag", "refId": "A"}
      ],
      "title": "Charts cache lag",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Live count of Island sandbox containers, broken out by isolation mode.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "id": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (isolation) (island_sandbox_count)", "legendFormat": "{{isolation}}", "refId": "A"}
      ],
      "title": "Island sandboxes (live)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Backend HTTP error rate per route, last 5m.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{namespace=\"progctf-fleet\", app_kubernetes_io_name=\"backend\", status=~\"5..\"}[5m])) / clamp_min(sum by (route) (rate(http_requests_total{namespace=\"progctf-fleet\", app_kubernetes_io_name=\"backend\"}[5m])), 0.001)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Error rate per route",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "P95 latency per backend route.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{namespace=\"progctf-fleet\", app_kubernetes_io_name=\"backend\"}[5m])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "P95 latency per route",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Edge nginx 429s per minute by path. Sustained spikes on /api/auth fire the CrewIsRiotingBoardingTheAuthEndpoint alert.",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "id": 6,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (path) (rate(nginx_http_requests_total{status=\"429\"}[5m]))", "legendFormat": "{{path}}", "refId": "A"}
      ],
      "title": "Edge 429s (rate-limit drops)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "WebSocket connections to /socket.io — live audience size.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "id": 7,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}},
      "targets": [
        {"expr": "sum(progctf_websocket_clients)", "refId": "A"}
      ],
      "title": "Live WebSocket clients",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Postgres backup age (hours). Should reset to ~0 every morning.",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 26}, {"color": "red", "value": 36}]}, "unit": "h"}, "overrides": []},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "id": 8,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [
        {"expr": "(time() - max(kube_job_status_completion_time{namespace=\"progctf-fleet\", job_name=~\"postgres-backup.*\"})) / 3600", "refId": "A"}
      ],
      "title": "Last successful backup",
      "type": "gauge"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["progctf", "the-voyage"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "The Voyage — overview",
  "uid": "the-voyage-overview",
  "version": 1,
  "weekStart": ""
}
